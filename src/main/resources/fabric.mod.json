{
	"schemaVersion": 1,
	"id": "eve",
	"version": "${version}",
	"name": "Extended Vanilla Endgame",
	"description": "Keeps Minecraft exactly vanilla until the endgame, where tools and armor can be upgraded to +1, +2, +3... at ever-increasing cost.",
	"authors": [
		"rok"
	],
	"license": "MIT",
	"icon": "assets/eve/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.rok.eve.EVE"
		],
		"jei_mod_plugin": [
			"dev.rok.eve.compat.jei.EVEJeiPlugin"
		]
	},
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": ">=26.1 <26.3",
		"java": ">=25",
		"fabric-api": "*"
	},
	"suggests": {
		"jei": "*"
	}
}
